---
import BaseLayout from '../layouts/BaseLayout.astro';

// Placeholder gallery items - replace with real images later
const galleryItems = [
  { id: 0, title: 'Turtle with Hoju jewels', category: 'Traditional', src: '/turtle-hoju-jewels.jpg' },
  { id: 1, title: 'Dog and flowers', category: 'Traditional', src: '/dog-flowers.jpg' },
  { id: 2, title: 'Japanese Dragon', category: 'Traditional', src: '/placeholder1.jpg' },
  { id: 3, title: 'Koi Fish', category: 'Japanese', src: '/placeholder2.jpg' },
  { id: 4, title: 'Cherry Blossom', category: 'Nature', src: '/placeholder3.jpg' },
  { id: 5, title: 'Samurai Portrait', category: 'Traditional', src: '/placeholder4.jpg' },
  { id: 6, title: 'Geisha', category: 'Japanese', src: '/placeholder5.jpg' },
  { id: 7, title: 'Phoenix', category: 'Mythology', src: '/placeholder6.jpg' },
  { id: 8, title: 'Wave Pattern', category: 'Traditional', src: '/placeholder7.jpg' },
  { id: 9, title: 'Lotus Flower', category: 'Nature', src: '/placeholder8.jpg' },
  { id: 10, title: 'Oni Mask', category: 'Japanese', src: '/placeholder9.jpg' },
];

const categories = ['All', ...new Set(galleryItems.map(item => item.category))];
---

<BaseLayout title="Gallery - Sengeki Tattoo Studio">
  <div class="container">
    <h1>Gallery</h1>
    <p class="subtitle">A collection of our finest work. Each piece tells a story.</p>
    
    <div class="filter-buttons">
      {categories.map(cat => (
        <button class={`filter-btn ${cat === 'All' ? 'active' : ''}`} data-category={cat}>
          {cat}
        </button>
      ))}
    </div>
    
    <div class="gallery-grid">
      {galleryItems.map(item => (
        <div class="gallery-item" data-category={item.category}>
          <img src={item.src} alt={item.title} />
          <div class="overlay">
            <h3>{item.title}</h3>
            <p>{item.category}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
  
  <style>
    .subtitle {
      color: #ccc;
      margin-bottom: 2rem;
      text-align: center;
    }
    
    .filter-buttons {
      display: flex;
      justify-content: center;
      gap: 1rem;
      margin-bottom: 2rem;
      flex-wrap: wrap;
    }
    
    .filter-btn {
      padding: 0.5rem 1.5rem;
      background-color: var(--secondary-color);
      border: 1px solid var(--border-color);
      color: var(--text-color);
      border-radius: 4px;
      cursor: pointer;
      transition: all 0.3s;
    }
    
    .filter-btn:hover,
    .filter-btn.active {
      background-color: var(--accent-color);
      color: var(--bg-color);
      border-color: var(--accent-color);
    }
    
    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1.5rem;
    }
    
    .gallery-item {
      position: relative;
      aspect-ratio: 1;
      background-color: var(--secondary-color);
      border-radius: 8px;
      overflow: hidden;
      cursor: pointer;
      border: 1px solid var(--border-color);
    }
    
    .gallery-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    
    .overlay {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      background: linear-gradient(transparent, rgba(0,0,0,0.9));
      padding: 1.5rem;
      transform: translateY(100%);
      transition: transform 0.3s;
    }
    
    .gallery-item:hover .overlay {
      transform: translateY(0);
    }
    
    .overlay h3 {
      color: var(--accent-color);
      margin-bottom: 0.25rem;
      font-size: 1.2rem;
    }
    
    .overlay p {
      color: #ccc;
      font-size: 0.9rem;
    }
  </style>
  
  <script>
    // Simple category filtering
    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const category = btn.getAttribute('data-category');
        
        // Update active button
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        
        // Filter items
        document.querySelectorAll('.gallery-item').forEach(item => {
          if (category === 'All' || item.getAttribute('data-category') === category) {
            item.style.display = 'block';
          } else {
            item.style.display = 'none';
          }
        });
      });
    });
  </script>
</BaseLayout>
